        ],
        "support": "official"
      }
    },
    {
      "id": "backend/python-fastapi",
      "path": "starters/backend/python-fastapi",
      "manifestPath": "starters/backend/python-fastapi/dflow.template.json",
      "manifest": {
        "schemaVersion": "1",
        "id": "backend/python-fastapi",
        "displayName": "Python FastAPI",
        "category": "backend",
        "language": "Python",
        "framework": "FastAPI",
        "runtime": "python",
        "installCommand": "python3 -m pip install -r requirements.txt",
        "buildCommand": "",
        "startCommand": "python3 -m uvicorn main:app --host 0.0.0.0 --port 8000",
        "port": 8000,
        "healthCheck": {
          "type": "http",
          "path": "/health",
          "expectedStatus": 200
        },
        "env": [
          {
            "name": "PORT",
            "required": false,
            "description": "HTTP listen port when you override the default (manifest default: 8000)."
          }
