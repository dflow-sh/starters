    {
      "id": "frontend/angular",
      "path": "starters/frontend/angular",
      "manifestPath": "starters/frontend/angular/dflow.template.json",
      "manifest": {
        "schemaVersion": "1",
        "id": "frontend/angular",
        "displayName": "Angular",
        "category": "frontend",
        "language": "TypeScript",
        "framework": "Angular",
        "runtime": "node",
        "installCommand": "npm ci",
        "buildCommand": "npm run build",
        "startCommand": "npm run preview",
        "port": 4173,
        "healthCheck": {
          "type": "http",
          "path": "/",
          "expectedStatus": 200
        },
        "outputs": {
          "staticDir": "dist/angular/browser"
        },
        "tags": [
          "angular",
          "spa"
        ],
        "support": "official"
      }
    },
    {
      "id": "frontend/react-vite",
      "path": "starters/frontend/react-vite",
      "manifestPath": "starters/frontend/react-vite/dflow.template.json",
      "manifest": {
        "schemaVersion": "1",
        "id": "frontend/react-vite",
        "displayName": "React (Vite)",
        "category": "frontend",
        "language": "TypeScript",
        "framework": "Vite",
        "runtime": "node",
        "installCommand": "npm install",
        "buildCommand": "npm run build",
        "startCommand": "npm run preview -- --host 0.0.0.0 --port ${PORT:-4173}",
        "port": 4173,
        "healthCheck": {
          "type": "http",
          "path": "/",
          "expectedStatus": 200
        },
        "outputs": {
          "staticDir": "dist"
        },
        "env": [
          {
            "name": "VITE_APP_TITLE",
            "required": false,
            "description": "Optional heading text; Vite exposes VITE_* to the client bundle (never put secrets in VITE_* vars)."
          }
        ],
        "tags": [
          "react",
          "vite",
          "spa"
        ],
        "support": "official"
      }
    },
    {
      "id": "frontend/vue-vite",
      "path": "starters/frontend/vue-vite",
