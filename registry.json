        "startCommand": "npm run preview -- --host 0.0.0.0 --port ${PORT:-4173}",
        "port": 4173,
        "healthCheck": {
          "type": "http",
          "path": "/",
          "expectedStatus": 200
        },
        "outputs": {
          "staticDir": "dist"
        },
        "env": [
