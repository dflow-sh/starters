{
  "schemaVersion": "1",
  "id": "backend/go-gin",
  "displayName": "Go (Gin)",
  "category": "backend",
  "language": "Go",
  "framework": "Gin",
  "runtime": "go",
  "installCommand": "go mod download",
  "buildCommand": "go build -o bin/server .",
  "startCommand": "./bin/server",
  "port": 8080,
  "healthCheck": {
    "type": "http",
    "path": "/health",
    "expectedStatus": 200
  },
  "env": [
    {
      "name": "PORT",
      "required": false,
      "description": "HTTP listen port when you override the default (manifest default: 8080)."
    }
  ],
  "tags": ["go", "gin", "api"],
  "support": "official"
}
